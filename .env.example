# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=your-secure-password-here
DATABASE_URL="postgresql://minepanel:${POSTGRES_PASSWORD}@postgres:5432/minepanel"

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here-make-it-long-and-random
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Login / Auth ─────────────────────────────────────────────────────────────
REQUIRE_ADMIN_APPROVAL=true          # true = new users start as PENDING, admin must approve
LOGIN_THROTTLE_LIMIT=5               # max login attempts per window
LOGIN_THROTTLE_TTL_MS=10000          # window duration in ms (default: 10s)

# ─── Encryption ───────────────────────────────────────────────────────────────
ENCRYPTION_KEY=rcon-secret-here-make-it-long-and-random

# ─── App ─────────────────────────────────────────────────────────────────────
DOMAIN=your-domain.com               # used by Caddy for automatic HTTPS + CORS
PORT=3000
NODE_ENV=development                 # development | production
CORS_ORIGIN="https://minepanel.xyz"  # in prod, set automatically from DOMAIN via docker-compose
PANEL_NAME="My MinePanel"
PANEL_DESCRIPTION="Minecraft server management panel API"
PANEL_VERSION="1.0"
PANEL_ASSETS_PATH="/panel-assets"    # bind-mount this path into the container

# ─── Docker ──────────────────────────────────────────────────────────────────
DOCKER_SOCKET="/var/run/docker.sock"
DOCKER_NETWORK="minepanel_network"
MC_DATA_PATH="/mc-data"
MC_PORT_MIN=25565
MC_PORT_MAX=25665
MIN_FREE_DISK_MB=2048
MAX_MEMORY_RATIO=0.90

# ─── SMTP (optional — enables email features) ────────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=noreply@example.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM=noreply@example.com

# ─── Minecraft linking (optional) ────────────────────────────────────────────
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
