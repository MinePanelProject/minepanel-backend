# Database
POSTGRES_PASSWORD=your-secure-password-here
DATABASE_URL="postgresql://minepanel:${POSTGRES_PASSWORD}@postgres:5432/minepanel"

# Rcon encryption
ENCRYPTION_KEY=rcon-secret-here-make-it-long-and-random

# JWT
JWT_SECRET=your-jwt-secret-here-make-it-long-and-random
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# App
PORT=3000
CORS_ORIGIN="http://localhost:5173"
NODE_ENV=development
PANEL_NAME="My MinePanel"
PANEL_DESCRIPTION="Minecraft server management panel API"
PANEL_VERSION="1.0"

# Docker (used in production container)
DOCKER_NETWORK="minepanel_network"
MC_DATA_PATH="/mc-data"
DOCKER_SOCKET="/var/run/docker.sock"