# Database
POSTGRES_PASSWORD=your-secure-password-here
DATABASE_URL="postgresql://minepanel:${POSTGRES_PASSWORD}@postgres:5432/minepanel"

# JWT
JWT_SECRET=your-jwt-secret-here-make-it-long-and-random
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# App
PORT=3000
CORS_ORIGIN="http://localhost:5173"

# Docker (used in production container)
DOCKER_NETWORK="minepanel_network"
MC_DATA_PATH="/mc-data"
